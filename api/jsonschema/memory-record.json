{
  "$id": "https://agentos.dev/schemas/memory-record.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoryRecord",
  "type": "object",
  "required": ["namespace", "type", "content", "sourceRef"],
  "properties": {
    "namespace": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["task", "session", "workspace", "catalog_fact", "user_pref", "evidence"]
    },
    "subjectRef": { "type": "string" },
    "content": { "type": "string" },
    "contentJson": { "type": "object", "additionalProperties": true },
    "classification": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sourceRef": { "type": "string" },
    "provenance": { "type": "object", "additionalProperties": true },
    "acl": { "type": "object", "additionalProperties": true },
    "retentionUntil": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
