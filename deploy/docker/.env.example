# Docker Compose environment for AgentOS local infra.
#
# Services run on the `agentos` bridge network. Published ports map to the host
# so agentosd on the host can use localhost URLs below.
#
# From another container on network `agentos`, use service DNS names:
#   postgres://agentos:agentos@postgres:5432/agentos?sslmode=disable
#   http://opa:8181

DATABASE_URL=postgres://agentos:agentos@localhost:5432/agentos?sslmode=disable
OPA_URL=http://localhost:8181
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
